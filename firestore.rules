rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * Model: Public Write (Anonymous) / Gated Read.
     * Verification is handled client-side via the '2137' code.
     * For the purpose of this prototype, we allow listing captured data 
     * for any authenticated user (including anonymous) to ensure the 
     * administrator can see results immediately after "verification".
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /captured_passwords/{capturedPasswordId} {
      // allow create if the user is signed in and provides a matching ID property
      allow create: if isSignedIn() && request.resource.data.id == capturedPasswordId;
      
      // allow read/list for signed in users (anonymous is fine for this prototype)
      // the '2137' code acts as the UI-level gate.
      allow get, list: if isSignedIn();
      
      allow update, delete: if false;
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list, create, update, delete: if false;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}